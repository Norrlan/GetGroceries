<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    android:backgroundTint="@color/white">

    <LinearLayout
        android:orientation="vertical"
        android:padding="12dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">


        <ImageView
            android:id="@+id/product_image"
            android:layout_width="402dp"
            android:layout_height="228dp"
            android:layout_gravity="center_horizontal"
            android:background="@color/greyblack"
            android:scaleType="centerCrop" />

        <Button
            android:id="@+id/save_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add to List"
            android:layout_marginTop="8dp"
            android:layout_gravity="center_horizontal"
            android:backgroundTint="@color/lime_green"
            android:textColor="@color/black"/>

        <TextView
            android:id="@+id/product_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Product Name"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="@color/black"
            android:paddingTop="8dp"/>


        <TextView
            android:id="@+id/product_category"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Product information"
            android:textColor="#666666"
            android:textSize="14sp"
            android:paddingTop="2dp"/>


        <TextView
            android:id="@+id/get_it_at"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Get it at"
            android:textStyle="bold"
            android:textSize="14sp"
            android:textColor="@color/black"
            android:paddingTop="12dp"/>

        <LinearLayout
            android:layout_width="292dp"
            android:layout_height="46dp"
            android:layout_gravity="left"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingLeft="35dp"
            android:paddingTop="4dp"
            android:paddingRight="40dp"
            android:src="@drawable/store_background">


            <ImageView
                android:id="@+id/store_logo"
                android:layout_width="66dp"
                android:layout_height="37dp"
                android:layout_marginRight="15dp"
                android:src="@drawable/search_background" />

            <ImageView
                android:id="@+id/external_link"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginLeft="18dp"
                android:layout_marginRight="15dp"
                android:src="@drawable/external_link" />

            <TextView
                android:id="@+id/product_price"
                android:layout_width="74dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="18dp"
                android:text="$0.00"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>